generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                String            @id @default(uuid())
  name              String
  slug              String            @unique
  address           Json
  contact           Json
  ownerId           String            @map("owner_id")
  businessInfo      Json              @map("business_info")
  subscription      Json
  settings          Json
  status            String            @default("active")
  stats             Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  analyticsDailies  AnalyticsDaily[]
  auditLogs         AuditLog[]
  businessUsers     BusinessUser[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  inventoryItems    InventoryItem[]
  menuItems         MenuItem[]
  orders            Order[]
  payments          Payment[]
  owner             User              @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tables            Table[]

  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("restaurants")
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  emailVerified    Boolean        @default(false) @map("email_verified")
  name             String?
  image            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  role             String?
  banned           Boolean?       @default(false)
  banReason        String?
  banExpires       DateTime?
  accounts         Account[]
  auditLogs        AuditLog[]
  businessUsers    BusinessUser[]
  expensesApproved Expense[]      @relation("ExpenseApprover")
  expensesCreated  Expense[]      @relation("ExpenseCreator")
  orders           Order[]
  payments         Payment[]      @relation("ProcessedPayments")
  ownedRestaurants Restaurant[]   @relation("RestaurantOwner")
  sessions         Session[]

  @@index([email])
  @@map("users")
}

model BusinessUser {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  userId       String     @map("user_id")
  role         String
  status       String     @default("active")
  permissions  String[]   @default([])
  joinedAt     DateTime   @default(now()) @map("joined_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@index([restaurantId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("business_users")
}

model MenuItem {
  id            String     @id @default(uuid())
  restaurantId  String     @map("restaurant_id")
  categories    Json
  menuVersion   Decimal    @default(1.0) @map("menu_version") @db.Decimal(4, 2)
  lastPublished DateTime?  @map("last_published")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([updatedAt])
  @@map("menu_items")
}

model InventoryItem {
  id              String     @id @default(uuid())
  restaurantId    String     @map("restaurant_id")
  name            String
  sku             String
  category        String
  currentStock    Decimal    @map("current_stock") @db.Decimal(10, 3)
  minimumStock    Decimal    @map("minimum_stock") @db.Decimal(10, 3)
  unit            String
  costPerUnit     Decimal    @map("cost_per_unit") @db.Decimal(10, 2)
  totalValue      Decimal    @map("total_value") @db.Decimal(10, 2)
  trackExpiry     Boolean    @default(false) @map("track_expiry")
  expiryDate      DateTime?  @map("expiry_date")
  transactions    Json[]     @default([])
  status          String     @default("in_stock")
  isActive        Boolean    @default(true) @map("is_active")
  linkedMenuItems Json[]     @default([]) @map("linked_menu_items")
  alerts          Json[]     @default([])
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, sku])
  @@index([restaurantId])
  @@index([category])
  @@index([status])
  @@index([currentStock])
  @@map("inventory_items")
}

model Order {
  id                      String     @id @default(uuid())
  orderNumber             String     @unique @map("order_number")
  restaurantId            String     @map("restaurant_id")
  tableId                 String?    @map("table_id")
  tableNumber             String?    @map("table_number")
  staffId                 String     @map("staff_id")
  staffName               String     @map("staff_name")
  orderType               String     @map("order_type")
  customerInfo            Json       @map("customer_info")
  items                   Json
  pricing                 Json
  discountsApplied        Json[]     @default([]) @map("discounts_applied")
  paymentStatus           String     @default("pending") @map("payment_status")
  balanceDue              Decimal    @default(0) @map("balance_due") @db.Decimal(10, 2)
  status                  String     @default("active")
  priority                String     @default("normal")
  estimatedCompletionTime DateTime?  @map("estimated_completion_time")
  actualCompletionTime    DateTime?  @map("actual_completion_time")
  feedback                Json?
  timestamps              Json
  auditTrail              Json[]     @default([]) @map("audit_trail")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  restaurant              Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  staff                   User       @relation(fields: [staffId], references: [id])
  table                   Table?     @relation(fields: [tableId], references: [id])
  payments                Payment[]

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([orderNumber])
  @@index([tableId])
  @@index([staffId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model Payment {
  id                   String     @id @default(uuid())
  restaurantId         String     @map("restaurant_id")
  orderId              String     @map("order_id")
  orderNumber          String     @map("order_number")
  paymentNumber        String     @unique @map("payment_number")
  amount               Decimal    @db.Decimal(10, 2)
  method               String
  status               String     @default("pending")
  gateway              String?
  gatewayTransactionId String?    @map("gateway_transaction_id")
  gatewayOrderId       String?    @map("gateway_order_id")
  gatewayResponse      Json?      @map("gateway_response")
  customerInfo         Json       @map("customer_info")
  billingAddress       Json?      @map("billing_address")
  taxDetails           Json       @map("tax_details")
  refunds              Json[]     @default([])
  receipt              Json?
  processedBy          String?    @map("processed_by")
  processedAt          DateTime?  @map("processed_at")
  settlementInfo       Json?      @map("settlement_info")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  order                Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processor            User?      @relation("ProcessedPayments", fields: [processedBy], references: [id])
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([gatewayTransactionId])
  @@index([paymentNumber])
  @@index([status])
  @@index([method])
  @@map("payments")
}

model Table {
  id             String     @id @default(uuid())
  restaurantId   String     @map("restaurant_id")
  tableNumber    String     @map("table_number")
  displayName    String     @map("display_name")
  capacity       Int
  position       Json
  shape          String     @default("square")
  dimensions     Json?
  status         String     @default("available") @map("status")
  qrCode         Json?      @map("qr_code")
  currentSession Json?      @map("current_session")
  reservations   Json[]     @default([])
  settings       Json
  maintenanceLog Json[]     @default([]) @map("maintenance_log")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  orders         Order[]
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@index([status])
  @@map("tables")
}

model AnalyticsDaily {
  id                String     @id @default(uuid())
  restaurantId      String     @map("restaurant_id")
  date              DateTime   @db.Date
  salesSummary      Json       @map("sales_summary")
  paymentMethods    Json       @map("payment_methods")
  topItems          Json[]     @default([]) @map("top_items")
  hourlyBreakdown   Json[]     @default([]) @map("hourly_breakdown")
  staffPerformance  Json[]     @default([]) @map("staff_performance")
  tablePerformance  Json[]     @default([]) @map("table_performance")
  customerInsights  Json       @map("customer_insights")
  inventoryConsumed Json[]     @default([]) @map("inventory_consumed")
  createdAt         DateTime   @default(now()) @map("created_at")
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date])
  @@index([restaurantId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([createdAt])
  @@map("analytics_daily")
}

model ExpenseCategory {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  name         String
  description  String?
  color        String
  icon         String?
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@index([restaurantId])
  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id                 String          @id @default(uuid())
  restaurantId       String          @map("restaurant_id")
  categoryId         String          @map("category_id")
  title              String
  description        String?
  amount             Decimal         @db.Decimal(10, 2)
  currency           String          @default("INR")
  expenseDate        DateTime        @map("expense_date")
  paymentMethod      String          @map("payment_method")
  vendorName         String?         @map("vendor_name")
  vendorContact      String?         @map("vendor_contact")
  receiptUrl         String?         @map("receipt_url")
  receiptNumber      String?         @map("receipt_number")
  taxAmount          Decimal?        @map("tax_amount") @db.Decimal(10, 2)
  taxPercentage      Decimal?        @map("tax_percentage") @db.Decimal(5, 2)
  isRecurring        Boolean         @default(false) @map("is_recurring")
  recurringFrequency String?         @map("recurring_frequency")
  recurringEndDate   DateTime?       @map("recurring_end_date")
  tags               String[]        @default([])
  status             String          @default("pending")
  approvedBy         String?         @map("approved_by")
  approvedAt         DateTime?       @map("approved_at")
  notes              String?
  createdBy          String          @map("created_by")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  approver           User?           @relation("ExpenseApprover", fields: [approvedBy], references: [id])
  category           ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator            User            @relation("ExpenseCreator", fields: [createdBy], references: [id])
  restaurant         Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, expenseDate(sort: Desc)])
  @@index([categoryId])
  @@index([status])
  @@index([createdBy])
  @@index([expenseDate(sort: Desc)])
  @@map("expenses")
}

model AuditLog {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  userId       String?    @map("user_id")
  action       String
  resource     String
  resourceId   String?    @map("resource_id")
  details      Json?
  ipAddress    String?    @map("ip_address")
  userAgent    String?    @map("user_agent")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id])

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  VIEWER
  ACCOUNTANT
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ONLINE
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NET_BANKING
  WALLET
  BANK_TRANSFER
  OTHER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  OUT_OF_SERVICE
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
