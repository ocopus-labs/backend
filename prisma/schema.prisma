generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  type              String             @default("restaurant") // Business type: restaurant, salon, gym, cafe, retail, etc.
  logo              String? // Cloudinary URL for business logo
  description       String? // Business description
  address           Json
  contact           Json
  ownerId           String             @map("owner_id")
  businessInfo      Json               @map("business_info")
  settings          Json
  status            String             @default("active")
  stats             Json?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  analyticsDailies  AnalyticsDaily[]
  auditLogs         AuditLog[]
  businessUsers     BusinessUser[]
  customers         Customer[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  inventoryItems    InventoryItem[]
  menuItems         MenuItem[]
  orders            Order[]
  payments          Payment[]
  franchiseId       String?            @map("franchise_id")
  configSource      String             @default("local") // "local" | "franchise" | "hybrid"
  owner             User               @relation("RestaurantOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  franchise         Franchise?         @relation("FranchiseBusinesses", fields: [franchiseId], references: [id])
  refunds           Refund[]
  stockTransactions StockTransaction[]
  tables            Table[]
  usageRecords      UsageRecord[]
  apiKeys           ApiKey[]
  loyaltyAccounts   LoyaltyAccount[]
  invoiceCounters   InvoiceCounter[]

  @@index([ownerId])
  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([franchiseId])
  @@map("restaurants")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  emailVerified          Boolean                 @default(false) @map("email_verified")
  name                   String?
  image                  String?
  role                   String? // For Better Auth admin plugin
  banned                 Boolean? // For Better Auth admin plugin
  banReason              String?                 @map("ban_reason")
  twoFactorEnabled       Boolean?                @default(false) @map("two_factor_enabled")
  preferences            Json?
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  accounts               Account[]
  auditLogs              AuditLog[]
  businessUsers          BusinessUser[]
  expensesApproved       Expense[]               @relation("ExpenseApprover")
  expensesCreated        Expense[]               @relation("ExpenseCreator")
  orders                 Order[]
  payments               Payment[]               @relation("ProcessedPayments")
  ownedRestaurants       Restaurant[]            @relation("RestaurantOwner")
  sessions               Session[]
  subscriptions          Subscription[]
  twoFactorEntries       TwoFactor[]
  announcements          Announcement[]
  announcementDismissals AnnouncementDismissal[]
  apiKeys                ApiKey[]
  ownedFranchises        Franchise[]             @relation("FranchiseOwner")
  franchiseUsers         FranchiseUser[]

  @@index([email])
  @@map("users")
}

model BusinessUser {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  userId       String     @map("user_id")
  role         String
  status       String     @default("active")
  permissions  String[]   @default([])
  joinedAt     DateTime   @default(now()) @map("joined_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@index([restaurantId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@map("business_users")
}

// ==================== FRANCHISE MODELS ====================

model Franchise {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  ownerId      String   @map("owner_id")
  logo         String?
  description  String?
  status       String   @default("active") // active, suspended, deleted
  settings     Json     @default("{}")
  menuTemplate Json?    @map("menu_template")
  branding     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner        User            @relation("FranchiseOwner", fields: [ownerId], references: [id])
  businesses   Restaurant[]    @relation("FranchiseBusinesses")
  staff        FranchiseUser[]
  subscription Subscription?   @relation("FranchiseSubscription")

  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@map("franchises")
}

model FranchiseUser {
  id          String   @id @default(uuid())
  franchiseId String   @map("franchise_id")
  userId      String   @map("user_id")
  role        String // franchise_owner, manager, viewer
  status      String   @default("active")
  permissions String[] @default([])
  joinedAt    DateTime @default(now()) @map("joined_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, userId])
  @@index([franchiseId])
  @@index([userId])
  @@map("franchise_users")
}

model MenuItem {
  id            String     @id @default(uuid())
  restaurantId  String     @map("restaurant_id")
  categories    Json
  menuVersion   Decimal    @default(1.0) @map("menu_version") @db.Decimal(4, 2)
  lastPublished DateTime?  @map("last_published")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([updatedAt])
  @@map("menu_items")
}

model InventoryItem {
  id              String     @id @default(uuid())
  restaurantId    String     @map("restaurant_id")
  name            String
  sku             String
  category        String
  currentStock    Decimal    @map("current_stock") @db.Decimal(10, 3)
  minimumStock    Decimal    @map("minimum_stock") @db.Decimal(10, 3)
  unit            String
  costPerUnit     Decimal    @map("cost_per_unit") @db.Decimal(10, 2)
  totalValue      Decimal    @map("total_value") @db.Decimal(10, 2)
  trackExpiry     Boolean    @default(false) @map("track_expiry")
  expiryDate      DateTime?  @map("expiry_date")
  transactions    Json[]     @default([])
  status          String     @default("in_stock")
  isActive        Boolean    @default(true) @map("is_active")
  linkedMenuItems Json[]     @default([]) @map("linked_menu_items")
  alerts          Json[]     @default([])
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  stockTransactions StockTransaction[]

  @@unique([restaurantId, sku])
  @@index([restaurantId])
  @@index([category])
  @@index([status])
  @@index([currentStock])
  @@map("inventory_items")
}

model StockTransaction {
  id              String        @id @default(uuid())
  inventoryItemId String        @map("inventory_item_id")
  restaurantId    String        @map("restaurant_id")
  type            String // add, remove, waste, adjust
  quantity        Decimal       @db.Decimal(10, 3)
  previousStock   Decimal       @map("previous_stock") @db.Decimal(10, 3)
  newStock        Decimal       @map("new_stock") @db.Decimal(10, 3)
  reason          String?
  reference       String?
  performedBy     String        @map("performed_by")
  performedAt     DateTime      @default(now()) @map("performed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId, performedAt(sort: Desc)])
  @@index([restaurantId])
  @@index([type])
  @@index([performedAt(sort: Desc)])
  @@map("stock_transactions")
}

model Customer {
  id           String   @id @default(uuid())
  restaurantId String   @map("restaurant_id")
  name         String
  phone        String
  email        String?
  taxId        String?  @map("tax_id")
  address      Json?
  notes        String?  @db.Text
  tags         String[] @default([])
  status       String   @default("active") // active | inactive
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders         Order[]
  loyaltyAccount LoyaltyAccount?

  @@unique([restaurantId, phone])
  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([restaurantId, phone])
  @@index([restaurantId, email])
  @@map("customers")
}

model Order {
  id                      String     @id @default(uuid())
  orderNumber             String     @unique @map("order_number")
  invoiceNumber           String?    @unique @map("invoice_number")
  restaurantId            String     @map("restaurant_id")
  customerId              String?    @map("customer_id")
  tableId                 String?    @map("table_id")
  tableNumber             String?    @map("table_number")
  staffId                 String?    @map("staff_id")
  staffName               String?    @map("staff_name")
  orderSource             String     @default("pos") @map("order_source")
  orderType               String     @map("order_type")
  customerInfo            Json       @map("customer_info")
  items                   Json
  pricing                 Json
  discountsApplied        Json[]     @default([]) @map("discounts_applied")
  paymentStatus           String     @default("pending") @map("payment_status")
  balanceDue              Decimal    @default(0) @map("balance_due") @db.Decimal(10, 2)
  status                  String     @default("active")
  priority                String     @default("normal")
  estimatedCompletionTime DateTime?  @map("estimated_completion_time")
  actualCompletionTime    DateTime?  @map("actual_completion_time")
  feedback                Json?
  timestamps              Json
  auditTrail              Json[]     @default([]) @map("audit_trail")
  deletedAt               DateTime?  @map("deleted_at")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  customer                Customer?  @relation(fields: [customerId], references: [id])
  restaurant              Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  staff                   User?      @relation(fields: [staffId], references: [id], onDelete: Restrict)
  table                   Table?     @relation(fields: [tableId], references: [id])
  payments                Payment[]

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([orderNumber])
  @@index([customerId])
  @@index([tableId])
  @@index([staffId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("orders")
}

model Payment {
  id                   String     @id @default(uuid())
  restaurantId         String     @map("restaurant_id")
  orderId              String     @map("order_id")
  orderNumber          String     @map("order_number")
  paymentNumber        String     @unique @map("payment_number")
  amount               Decimal    @db.Decimal(10, 2)
  method               String
  status               String     @default("pending")
  gateway              String?
  gatewayTransactionId String?    @map("gateway_transaction_id")
  gatewayOrderId       String?    @map("gateway_order_id")
  gatewayResponse      Json?      @map("gateway_response")
  customerInfo         Json       @map("customer_info")
  billingAddress       Json?      @map("billing_address")
  taxDetails           Json       @map("tax_details")
  refunds              Json[]     @default([])
  receipt              Json?
  processedBy          String?    @map("processed_by")
  processedAt          DateTime?  @map("processed_at")
  settlementInfo       Json?      @map("settlement_info")
  deletedAt            DateTime?  @map("deleted_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  order                Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processor            User?      @relation("ProcessedPayments", fields: [processedBy], references: [id])
  restaurant           Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  refundRecords Refund[]

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([orderId])
  @@index([gatewayTransactionId])
  @@index([paymentNumber])
  @@index([status])
  @@index([method])
  @@index([deletedAt])
  @@map("payments")
}

model Refund {
  id           String     @id @default(uuid())
  paymentId    String     @map("payment_id")
  restaurantId String     @map("restaurant_id")
  amount       Decimal    @db.Decimal(10, 2)
  reason       String
  method       String // original, cash, store_credit, etc.
  refundedBy   String     @map("refunded_by")
  refundedAt   DateTime   @default(now()) @map("refunded_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  payment      Payment    @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([paymentId, refundedAt(sort: Desc)])
  @@index([restaurantId])
  @@index([refundedAt(sort: Desc)])
  @@map("refunds")
}

model Table {
  id             String     @id @default(uuid())
  restaurantId   String     @map("restaurant_id")
  tableNumber    String     @map("table_number")
  displayName    String     @map("display_name")
  capacity       Int
  position       Json
  shape          String     @default("square")
  dimensions     Json?
  status         String     @default("available") @map("status")
  qrCode         Json?      @map("qr_code")
  currentSession Json?      @map("current_session")
  reservations   Json[]     @default([])
  settings       Json
  maintenanceLog Json[]     @default([]) @map("maintenance_log")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  orders         Order[]
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@index([status])
  @@map("tables")
}

model AnalyticsDaily {
  id                String     @id @default(uuid())
  restaurantId      String     @map("restaurant_id")
  date              DateTime   @db.Date
  salesSummary      Json       @map("sales_summary")
  paymentMethods    Json       @map("payment_methods")
  topItems          Json[]     @default([]) @map("top_items")
  hourlyBreakdown   Json[]     @default([]) @map("hourly_breakdown")
  staffPerformance  Json[]     @default([]) @map("staff_performance")
  tablePerformance  Json[]     @default([]) @map("table_performance")
  customerInsights  Json       @map("customer_insights")
  inventoryConsumed Json[]     @default([]) @map("inventory_consumed")
  createdAt         DateTime   @default(now()) @map("created_at")
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date])
  @@index([restaurantId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@index([createdAt])
  @@map("analytics_daily")
}

model ExpenseCategory {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  name         String
  description  String?
  color        String
  icon         String?
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@index([restaurantId])
  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id                 String          @id @default(uuid())
  restaurantId       String          @map("restaurant_id")
  categoryId         String          @map("category_id")
  title              String
  description        String?
  amount             Decimal         @db.Decimal(10, 2)
  currency           String          @default("INR")
  expenseDate        DateTime        @map("expense_date")
  paymentMethod      String          @map("payment_method")
  vendorName         String?         @map("vendor_name")
  vendorContact      String?         @map("vendor_contact")
  receiptUrl         String?         @map("receipt_url")
  receiptNumber      String?         @map("receipt_number")
  taxAmount          Decimal?        @map("tax_amount") @db.Decimal(10, 2)
  taxPercentage      Decimal?        @map("tax_percentage") @db.Decimal(5, 2)
  isRecurring        Boolean         @default(false) @map("is_recurring")
  recurringFrequency String?         @map("recurring_frequency")
  recurringEndDate   DateTime?       @map("recurring_end_date")
  tags               String[]        @default([])
  status             String          @default("pending")
  approvedBy         String?         @map("approved_by")
  approvedAt         DateTime?       @map("approved_at")
  notes              String?
  createdBy          String          @map("created_by")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  approver           User?           @relation("ExpenseApprover", fields: [approvedBy], references: [id])
  category           ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator            User            @relation("ExpenseCreator", fields: [createdBy], references: [id])
  restaurant         Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, expenseDate(sort: Desc)])
  @@index([categoryId])
  @@index([status])
  @@index([createdBy])
  @@index([expenseDate(sort: Desc)])
  @@map("expenses")
}

model AuditLog {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  userId       String?    @map("user_id")
  action       String
  resource     String
  resourceId   String?    @map("resource_id")
  details      Json?
  ipAddress    String?    @map("ip_address")
  userAgent    String?    @map("user_agent")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id])

  @@index([restaurantId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model TwoFactor {
  id          String @id @default(uuid())
  secret      String
  backupCodes String @map("backup_codes")
  userId      String @map("user_id")
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factor")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

// ==================== INVOICE COUNTER MODEL ====================

model InvoiceCounter {
  id            String     @id @default(uuid())
  restaurantId  String     @map("restaurant_id")
  financialYear String     @map("financial_year")
  lastNumber    Int        @default(0) @map("last_number")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, financialYear])
  @@index([restaurantId])
  @@map("invoice_counters")
}

// ==================== LOYALTY MODELS ====================

model LoyaltyAccount {
  id             String   @id @default(uuid())
  customerId     String   @unique @map("customer_id")
  restaurantId   String   @map("restaurant_id")
  points         Int      @default(0)
  lifetimePoints Int      @default(0) @map("lifetime_points")
  tier           String   @default("bronze") // bronze, silver, gold, platinum
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([restaurantId])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id               String   @id @default(uuid())
  loyaltyAccountId String   @map("loyalty_account_id")
  type             String // earn | redeem | adjust | expire
  points           Int // positive for earn, negative for redeem
  balance          Int // balance after transaction
  orderId          String?  @map("order_id")
  description      String
  createdBy        String?  @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  account LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([loyaltyAccountId, createdAt(sort: Desc)])
  @@index([orderId])
  @@map("loyalty_transactions")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  VIEWER
  ACCOUNTANT
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ONLINE
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NET_BANKING
  WALLET
  BANK_TRANSFER
  OTHER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  OUT_OF_SERVICE
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// ==================== SUBSCRIPTION MODELS ====================

model SubscriptionPlan {
  id          String  @id @default(uuid())
  name        String  @unique // "FREE", "PRO", "ENTERPRISE"
  slug        String  @unique // "free", "pro", "enterprise"
  displayName String  @map("display_name")
  description String?

  // Pricing
  priceMonthly Decimal  @default(0) @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal? @map("price_yearly") @db.Decimal(10, 2)
  currency     String   @default("INR")

  // Dodo Integration
  dodoProductId String? @unique @map("dodo_product_id")

  // Account Limits (-1 = unlimited)
  maxLocations      Int @map("max_locations")
  maxTeamMembers    Int @map("max_team_members")
  maxOrdersPerMonth Int @map("max_orders_per_month")

  // Feature Flags
  features Json // { kitchenDisplay, analytics, inventory, expenses, api, whiteLabel }

  // Metadata
  isPublic  Boolean @default(true) @map("is_public")
  sortOrder Int     @default(0) @map("sort_order")
  status    String  @default("active") // active, archived

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@index([slug])
  @@index([status])
  @@index([isPublic])
  @@map("subscription_plans")
}

model Subscription {
  id     String @id @default(uuid())
  userId String @map("user_id")
  planId String @map("plan_id")

  // Status: active, past_due, canceled, trialing
  status String @default("active")

  // Billing Period
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime? @map("canceled_at")

  // Trial
  trialStart DateTime? @map("trial_start")
  trialEnd   DateTime? @map("trial_end")

  // Dodo Integration
  dodoSubscriptionId String? @unique @map("dodo_subscription_id")
  dodoCustomerId     String? @map("dodo_customer_id")

  // Metadata
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Franchise-level subscription (optional)
  franchiseId String? @unique @map("franchise_id")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  franchise    Franchise?       @relation("FranchiseSubscription", fields: [franchiseId], references: [id])
  usageRecords UsageRecord[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([dodoSubscriptionId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model UsageRecord {
  id             String @id @default(uuid())
  subscriptionId String @map("subscription_id")
  restaurantId   String @map("restaurant_id")

  // Period
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  // Usage Metrics
  ordersCount Int @default(0) @map("orders_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, restaurantId, periodStart])
  @@index([subscriptionId])
  @@index([restaurantId])
  @@index([periodStart])
  @@map("usage_records")
}

model WebhookEvent {
  id           String    @id @default(uuid())
  provider     String    @default("dodo") // dodo, razorpay, stripe
  eventType    String    @map("event_type")
  eventId      String    @unique @map("event_id") // webhook-id header for idempotency
  payload      Json
  status       String    @default("pending") // pending, processed, failed
  processedAt  DateTime? @map("processed_at")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider, eventType])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}

// ==================== ANNOUNCEMENT MODELS ====================

model Announcement {
  id         String    @id @default(uuid())
  title      String
  content    String    @db.Text
  type       String    @default("info") // info, warning, critical, maintenance
  target     String    @default("all") // all, business_owners, staff, specific_plan
  targetMeta Json?     @map("target_meta")
  isActive   Boolean   @default(true) @map("is_active")
  isPinned   Boolean   @default(false) @map("is_pinned")
  publishAt  DateTime? @map("publish_at")
  expiresAt  DateTime? @map("expires_at")
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  creator    User                    @relation(fields: [createdBy], references: [id])
  dismissals AnnouncementDismissal[]

  @@index([isActive, publishAt])
  @@index([expiresAt])
  @@index([type])
  @@map("announcements")
}

model AnnouncementDismissal {
  id             String   @id @default(uuid())
  announcementId String   @map("announcement_id")
  userId         String   @map("user_id")
  dismissedAt    DateTime @default(now()) @map("dismissed_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_dismissals")
}

// ==================== IMPERSONATION MODELS ====================

model ImpersonationSession {
  id             String   @id @default(uuid())
  adminUserId    String   @map("admin_user_id")
  targetUserId   String   @map("target_user_id")
  adminSessionId String   @unique @map("admin_session_id")
  impSessionId   String   @unique @map("imp_session_id")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  @@index([adminUserId])
  @@index([impSessionId])
  @@map("impersonation_sessions")
}

// ==================== API KEY MODELS ====================

model ApiKey {
  id           String    @id @default(uuid())
  name         String
  keyPrefix    String    @unique @map("key_prefix")
  keyHash      String    @unique @map("key_hash")
  userId       String    @map("user_id")
  restaurantId String    @map("restaurant_id")
  permissions  String[]  @default([])
  scopes       String[]  @default([])
  lastUsedAt   DateTime? @map("last_used_at")
  expiresAt    DateTime? @map("expires_at")
  isActive     Boolean   @default(true) @map("is_active")
  rateLimit    Int       @default(60) @map("rate_limit")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@index([restaurantId])
  @@map("api_keys")
}
