# Database
DATABASE_URL=postgresql://user:password@localhost:5432/billing_system

# Port
PORT=3000
NODE_ENV=development

# Resend Mail Configuration
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=noreply@yourdomain.com
RESEND_BASE_URL=https://api.resend.com

# Better Auth Configuration
BETTER_AUTH_SECRET=your-super-secret-key-change-in-production
AUTH_BASE_URL=http://localhost:3000

# Session Configuration
SESSION_EXPIRY_DAYS=7
SESSION_UPDATE_AGE_DAYS=1

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Dodo Payments Configuration
DODO_PAYMENTS_API_KEY=your_dodo_payments_api_key
DODO_PAYMENTS_WEBHOOK_SECRET=your_dodo_payments_webhook_secret
